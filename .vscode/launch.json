{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MiniCode Extension Demo",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension"
      ],
      "preLaunchTask": "minicode: demo"
    }
  ]
}
